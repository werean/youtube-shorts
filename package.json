{
  "name": "youtube-shorts",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "bun install && cd backend && bun install && cd ../frontend && bun install",
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd backend && bun run --watch src/main.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "start": "cd backend && bun run dist/main.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
